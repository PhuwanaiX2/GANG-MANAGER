# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Database (Turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Cloudinary Uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PREMIUM=price_your_premium_monthly_price_id
STRIPE_PRICE_PREMIUM_YEARLY=price_your_premium_yearly_price_id

# Discord Webhook (Error logging & monitoring)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Bot Backup
BACKUP_CHANNEL_ID=your_backup_channel_id
BOT_PORT=8080

# Admin
ADMIN_DISCORD_IDS=123456789,987654321

# Optional: Attendance E2E / CI
PLAYWRIGHT_RUN_ATTENDANCE_SMOKE=0
E2E_BASE_URL=http://127.0.0.1:3000
E2E_GANG_ID=your_e2e_gang_id
E2E_DISCORD_ID=your_e2e_discord_id
E2E_DISCORD_ACCESS_TOKEN=your_e2e_discord_access_token
E2E_USER_NAME=Playwright Attendance Officer
E2E_USER_EMAIL=playwright@example.com

# Debug (set to 'true' ONLY in development)
# ENABLE_DEBUG_ROUTES=true

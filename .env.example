# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
# Optional override. Defaults to client id 1468534739911573544 with bot + applications.commands scope.
DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=1468534739911573544&permissions=2416036880&scope=bot+applications.commands

# Database (Turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
# Optional for local Docker if your main NEXTAUTH_URL points at production
# LOCAL_NEXTAUTH_URL=http://localhost:3000

# Cloudinary Uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Billing
# ENV is the outer safety switch. Admin > Feature Flags can still pause billing/auto-verify when these are true.
# Keep false until product readiness is clear and payment operations are ready.
ENABLE_PROMPTPAY_BILLING=false
ENABLE_SLIPOK_AUTO_VERIFY=false

# PromptPay / SlipOK billing
# Required when ENABLE_PROMPTPAY_BILLING=true.
PROMPTPAY_RECEIVER_NAME=your_receiver_display_name
PROMPTPAY_IDENTIFIER=your_promptpay_id_or_phone
# Required when ENABLE_SLIPOK_AUTO_VERIFY=true.
SLIPOK_API_KEY=your_slipok_api_key
SLIPOK_BRANCH_ID=your_slipok_branch_id
# Optional override, defaults to https://api.slipok.com/api/line/apikey
# SLIPOK_API_BASE_URL=https://api.slipok.com/api/line/apikey
# Optional extra HTTPS hosts for pasted slip image links. Discord/Facebook CDN and Cloudinary are trusted by default.
# Supports exact hosts or wildcards such as *.your-cdn.example.com.
# TRUSTED_SLIP_IMAGE_HOSTS=pay-cdn.example.com,*.your-cdn.example.com

# Health diagnostics (temporary only for release verification)
EXPOSE_HEALTH_DIAGNOSTICS=false

# Monitoring / alert webhook
# Used by web/bot structured error logs and scripts/monitor-production.mjs.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TOKEN=

# Bot Backup
BACKUP_CHANNEL_ID=your_backup_channel_id
BOT_PORT=8080

# Admin
ADMIN_DISCORD_IDS=123456789,987654321

# Optional: Attendance E2E / CI
PLAYWRIGHT_RUN_PRODUCTION_SMOKE=0
PLAYWRIGHT_RUN_ATTENDANCE_SMOKE=0
E2E_BASE_URL=http://127.0.0.1:3000
E2E_GANG_ID=your_e2e_gang_id
E2E_FINANCE_LOCKED_GANG_ID=your_free_gang_id
E2E_FINANCE_LOCKED_DISCORD_ID=your_free_gang_member_discord_id
E2E_EXPECT_ADMIN=0
E2E_ADMIN_DISCORD_ID=your_admin_discord_id
E2E_DISCORD_ID=your_e2e_discord_id
E2E_DISCORD_ACCESS_TOKEN=your_e2e_discord_access_token
# Optional: set this when Playwright tests target Docker/runtime with a different NEXTAUTH_SECRET than apps/web/.env.local.
E2E_NEXTAUTH_SECRET=your_runtime_nextauth_secret_for_e2e
E2E_USER_NAME=Playwright Attendance Officer
E2E_USER_EMAIL=playwright@example.com

# Debug (set to 'true' ONLY in development)
# ENABLE_DEBUG_ROUTES=true
